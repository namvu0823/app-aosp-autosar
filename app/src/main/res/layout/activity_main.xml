<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aurora_background"
    tools:context=".MainActivity">

    <!-- Main Content: car model ~60%, status+control+settings ~40% -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Center: car model, ~60% width -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:background="@drawable/glass_panel"
            android:elevation="6dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:padding="24dp"
                android:contentDescription="@string/title_car_model"
                android:scaleType="fitCenter"
                android:src="@drawable/tesla" />

            <ImageButton
                android:id="@+id/btnOpenCanDebug"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/glass_panel"
                android:elevation="4dp"
                android:padding="8dp"
                android:contentDescription="@string/title_can_debug"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/dashboard_on_surface_variant" />

            <!-- CAN read/write monitor overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_margin="12dp"
                android:background="@drawable/glass_panel"
                android:backgroundTint="@color/glass_bg"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/title_can_monitor"
                        android:textColor="@color/dashboard_on_surface_variant"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/tvCanStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NULL"
                        android:textColor="@color/warning_red"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCanRx"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text=""
                    android:textColor="@color/electric_blue"
                    android:textSize="12sp"
                    android:maxLines="5"
                    android:minLines="1"
                    android:ellipsize="none" />

                <TextView
                    android:id="@+id/tvCanTx"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text=""
                    android:textColor="@color/neon_green"
                    android:textSize="12sp"
                    android:maxLines="5"
                    android:minLines="1"
                    android:ellipsize="none" />
            </LinearLayout>
        </FrameLayout>

        <Space android:layout_width="18dp" android:layout_height="wrap_content" />

        <!-- Right: status + light control + diagnostics/settings, ~40% width -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/title_vehicle_status"
                        android:textColor="@color/dashboard_on_surface_variant"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:textAllCaps="true" />

                    <!-- Door + Climate mini-cards, side by side -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/glass_panel"
                            android:elevation="6dp"
                            android:padding="14dp">

                            <ImageView
                                android:id="@+id/ivDoorLock"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/glass_panel"
                                android:elevation="2dp"
                                android:padding="10dp"
                                android:src="@android:drawable/ic_lock_lock"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:tint="@color/neon_green" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                app:layout_constraintStart_toEndOf="@id/ivDoorLock"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/title_door_status"
                                    android:textColor="@color/dashboard_on_surface_variant"
                                    android:textSize="14sp"
                                    android:maxLines="1" />

                                <TextView
                                    android:id="@+id/tvDoorStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/door_locked"
                                    android:textColor="@color/neon_green"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:maxLines="1" />
                            </LinearLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <Space android:layout_width="12dp" android:layout_height="wrap_content" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/glass_panel"
                            android:elevation="6dp"
                            android:padding="14dp">

                            <ImageView
                                android:id="@+id/ivFan"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:padding="10dp"
                                android:src="@drawable/ic_fan"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:tint="@color/electric_blue" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                app:layout_constraintStart_toEndOf="@id/ivFan"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/title_climate_status"
                                    android:textColor="@color/dashboard_on_surface_variant"
                                    android:textSize="14sp"
                                    android:maxLines="1" />

                                <TextView
                                    android:id="@+id/tvClimateStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/climate_on"
                                    android:textColor="@color/electric_blue"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:maxLines="1" />
                            </LinearLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>

                    <Space android:layout_width="wrap_content" android:layout_height="14dp" />

                    <!-- Fuel: value + status on one row, bar below -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/glass_panel"
                        android:elevation="6dp"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="bottom">

                                <TextView
                                    android:id="@+id/tvFuelPercent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="78"
                                    android:textColor="@color/dashboard_on_surface"
                                    android:textSize="30sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="2dp"
                                    android:text="%"
                                    android:textColor="@color/dashboard_on_surface_variant"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:layout_marginBottom="4dp"
                                    android:text="nhiên liệu"
                                    android:textColor="@color/dashboard_on_surface_variant"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvFuelStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="@string/fuel_status_normal"
                                android:textColor="@color/neon_green"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                        </RelativeLayout>

                        <ProgressBar
                            android:id="@+id/pbFuel"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:layout_marginTop="12dp"
                            android:progress="78"
                            android:progressDrawable="@drawable/fuel_progress_drawable" />
                    </LinearLayout>

                    <Space android:layout_width="wrap_content" android:layout_height="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/title_light_control"
                        android:textColor="@color/dashboard_on_surface_variant"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:textAllCaps="true" />

                    <!-- Light control card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/glass_panel"
                        android:elevation="6dp"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/title_light_switch"
                                android:textColor="@color/dashboard_on_surface"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <Switch
                                android:id="@+id/switchLights"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:scaleX="1.3"
                                android:scaleY="1.3"
                                android:thumbTint="@color/white"
                                android:trackTint="@color/switch_track_tint" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/glass_panel"
                            android:backgroundTint="@color/dashboard_surface_container"
                            android:elevation="1dp"
                            android:orientation="horizontal"
                            android:padding="4dp">

                            <Button
                                android:id="@+id/btnNormal"
                                style="?android:attr/borderlessButtonStyle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:minHeight="48dp"
                                android:background="@drawable/glass_panel"
                                android:backgroundTint="@color/dashboard_surface_container"
                                android:text="@string/btn_normal"
                                android:textColor="@color/dashboard_on_surface"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnBlink"
                                style="?android:attr/borderlessButtonStyle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:minHeight="48dp"
                                android:text="@string/btn_blink"
                                android:textColor="@color/dashboard_on_surface_variant"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvLightState"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center"
                            android:text="@string/light_state_off"
                            android:textColor="@color/dashboard_on_surface_variant"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLightMode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/light_mode_solid"
                            android:textColor="@color/dashboard_on_surface_variant"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLightError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="#FDECEB"
                            android:padding="10dp"
                            android:text="@string/error_light_command"
                            android:textColor="#D64545"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:visibility="gone" />
                    </LinearLayout>

                    <Space android:layout_width="wrap_content" android:layout_height="14dp" />

                    <!-- VIN ID card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/glass_panel"
                        android:elevation="6dp"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/title_vin_id"
                                android:textColor="@color/dashboard_on_surface"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnReadVin"
                                style="?android:attr/borderlessButtonStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/glass_panel"
                                android:backgroundTint="@color/dashboard_surface_container"
                                android:paddingHorizontal="18dp"
                                android:paddingVertical="8dp"
                                android:text="@string/btn_read_vin"

                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvVinId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="monospace"
                            android:text="@string/vin_not_read"
                            android:textColor="@color/dashboard_on_surface_variant"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <Space android:layout_width="wrap_content" android:layout_height="14dp" />

                    <!-- Warning threshold card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/glass_panel"
                        android:elevation="6dp"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/title_warning_threshold"
                            android:textColor="@color/dashboard_on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etThreshold"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/glass_panel"
                            android:backgroundTint="@color/dashboard_background"
                            android:hint="@string/hint_threshold"
                            android:inputType="number"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/dashboard_on_surface"
                            android:textColorHint="@color/dashboard_on_surface_variant"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/btnSave"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="12dp"
                            android:elevation="4dp"
                            android:background="@drawable/gradient_button"
                            android:text="@string/btn_save"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvThresholdResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:padding="10dp"
                            android:gravity="center"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
