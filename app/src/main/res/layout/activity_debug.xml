<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aurora_background"
    android:padding="20dp"
    tools:context=".DebugActivity">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/rowTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/glass_panel"
            android:elevation="4dp"
            android:padding="8dp"
            android:contentDescription="@string/btn_back"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/dashboard_on_surface_variant" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="@string/title_can_debug"
            android:textColor="@color/dashboard_on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnToggleReading"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_panel"
            android:backgroundTint="@color/dashboard_surface_container"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:text="@string/btn_stop_reading"
            android:textColor="@color/dashboard_on_surface"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Send card -->
    <LinearLayout
        android:id="@+id/cardSend"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/glass_panel"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/rowTopBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/title_can_send"
            android:textColor="@color/dashboard_on_surface_variant"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:textAllCaps="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etCanId"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/glass_panel"
                android:backgroundTint="@color/dashboard_background"
                android:fontFamily="monospace"
                android:hint="@string/hint_can_id"
                android:inputType="textVisiblePassword"
                android:paddingHorizontal="14dp"
                android:textColor="@color/dashboard_on_surface"
                android:textColorHint="@color/dashboard_on_surface_variant"
                android:textSize="16sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etCanData"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/glass_panel"
            android:backgroundTint="@color/dashboard_background"
            android:fontFamily="monospace"
            android:hint="@string/hint_can_data"
            android:inputType="textVisiblePassword"
            android:paddingHorizontal="14dp"
            android:textColor="@color/dashboard_on_surface"
            android:textColorHint="@color/dashboard_on_surface_variant"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cbExtended"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_extended_frame"
                android:textColor="@color/dashboard_on_surface" />

            <Button
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:elevation="4dp"
                android:background="@drawable/gradient_button"
                android:paddingHorizontal="24dp"
                android:text="@string/btn_can_send"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Log card -->
    <LinearLayout
        android:id="@+id/cardLog"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/glass_panel"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardSend"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_can_log"
                android:textColor="@color/dashboard_on_surface_variant"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:textAllCaps="true" />

            <Button
                android:id="@+id/btnClearLog"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:text="@string/btn_clear_log"
                android:textColor="@color/dashboard_on_surface_variant"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text=""
                android:textColor="@color/dashboard_on_surface"
                android:textIsSelectable="true"
                android:textSize="13sp" />
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
